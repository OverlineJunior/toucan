{
	"name": "@rbxts/toucan",
	"version": "0.5.1",
	"main": "out/init.lua",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"setup": "bun i && bun i --cwd test && bun i --cwd docs && rokit install",
		"build": "rbxtsc",
		"dev": "concurrently -n \"LIB,TEST,ROJO\" -c \"blue,magenta,yellow\" \"rbxtsc -w\" \"rbxtsc -p test -w\" \"rojo serve test/default.project.json\"",
		"prepublishOnly": "bun run build",
		"lint": "biome check --write .",
		"format": "biome format --write .",
		"predev": "rbxtsc && rbxtsc -p test",
		"preinstall": "npx only-allow bun"
	},
	"keywords": [
		"ecs",
		"framework",
		"roblox"
	],
	"author": "OverlineJunior",
	"license": "MIT",
	"type": "commonjs",
	"description": "Entity Component System framework for Roblox-TS that favors developer experience.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OverlineJunior/toucan.git"
	},
	"bugs": {
		"url": "https://github.com/OverlineJunior/toucan/issues"
	},
	"homepage": "https://github.com/OverlineJunior/toucan#readme",
	"sideEffects": false,
	"types": "out/index.d.ts",
	"files": [
		"out",
		"!**/*.tsbuildinfo"
	],
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@rbxts/compiler-types": "^3.0.0-types.0",
		"@rbxts/types": "^1.0.918",
		"concurrently": "^9.2.1",
		"roblox-ts": "^3.0.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@rbxts/jecs": "^0.10.4",
		"@rbxts/services": "^1.6.0"
	}
}

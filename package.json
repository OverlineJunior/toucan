{
  "name": "@rbxts/toucan",
  "workspaces": [
    "docs"
  ],
  "version": "0.4.1",
  "main": "out/init.lua",
  "scripts": {
    "build": "rbxtsc",
    "watch": "yalc-watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint ./src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "packInstall": "rimraf --glob \"*.tgz\" && npm run build && npm pack && cd ../toucan-test && npm i ../toucan/*.tgz"
  },
  "keywords": [
    "ecs",
    "framework",
    "roblox"
  ],
  "author": "OverlineJunior",
  "license": "MIT",
  "type": "commonjs",
  "description": "Entity Component System framework for Roblox-TS that favors developer experience.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OverlineJunior/toucan.git"
  },
  "bugs": {
    "url": "https://github.com/OverlineJunior/toucan/issues"
  },
  "homepage": "https://github.com/OverlineJunior/toucan#readme",
  "sideEffects": false,
  "types": "out/index.d.ts",
  "files": [
    "out",
    "!**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "yalcWatch": {
    "watchFolder": "src",
    "buildWatchCommand": "rbxtsc -w",
    "extensions": "ts, luau"
  },
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/types": "^1.0.894",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-roblox-ts": "^1.3.0",
    "prettier": "^3.7.3",
    "rimraf": "^6.1.2",
    "roblox-ts": "^3.0.0",
    "typescript": "^5.9.3",
    "yalc-watch": "^0.0.6"
  },
  "dependencies": {
    "@rbxts/jecs": "^0.10.4",
    "@rbxts/planck": "^0.3.0-alpha.1",
    "@rbxts/services": "^1.6.0"
  }
}

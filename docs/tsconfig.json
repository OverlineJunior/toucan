{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    // TypeDoc needs these to simulate the Roblox environment
    "moduleResolution": "Node",
    "target": "ESNext",
    "noLib": false,
    "lib": ["ESNext"],
    "types": ["@rbxts/types"]
  },
  "include": [
    "../src/**/*"
  ],
  "exclude": [
    "../node_modules",
    "node_modules",
    "src",
    "astro.config.mjs"
  ]
}
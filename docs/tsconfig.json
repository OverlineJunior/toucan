{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"module": "CommonJS",
		"moduleResolution": "Node",
		"resolveJsonModule": true,
		"strict": false,
		"target": "ES2020",
		"lib": ["ES2020"],
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["../src/**/*"],
	"exclude": ["../node_modules", "node_modules", "src", "astro.config.mjs"]
}
